"""
Pretrained Encoder UNet for WRF Downscaling

UNet architecture with pretrained encoders (ResNet, EfficientNet)
for improved feature extraction and transfer learning.
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
import torchvision.models as models
from typing import Optional, List, Dict


class PretrainedEncoder(nn.Module):
    """Wrapper for pretrained encoders (ResNet, EfficientNet)."""
    
    ENCODER_CONFIGS = {
        # ResNet variants
        "resnet18": {
            "model": models.resnet18,
            "features": [64, 128, 256, 512],
            "output_stride": 32,
        },
        "resnet34": {
            "model": models.resnet34,
            "features": [64, 128, 256, 512],
            "output_stride": 32,
        },
        "resnet50": {
            "model": models.resnet50,
            "features": [256, 512, 1024, 2048],
            "output_stride": 32,
        },
        "resnet101": {
            "model": models.resnet101,
            "features": [256, 512, 1024, 2048],
            "output_stride": 32,
        },
        # EfficientNet variants
        "efficientnet_b0": {
            "model": models.efficientnet_b0,
            "features": [24, 40, 112, 320],
            "output_stride": 32,
        },
        "efficientnet_b1": {
            "model": models.efficientnet_b1,
            "features": [24, 40, 112, 320],
            "output_stride": 32,
        },
        "efficientnet_b2": {
            "model": models.efficientnet_b2,
            "features": [24, 48, 120, 352],
            "output_stride": 32,
        },
    }
    
    def __init__(
        self,
        encoder_name: str = "resnet18",
        pretrained: bool = True,
        in_channels: int = 7,
        frozen_stages: int = -1,  # -1 = no freezing
    ):
        super().__init__()
        
        if encoder_name not in self.ENCODER_CONFIGS:
            raise ValueError(
                f"Unknown encoder: {encoder_name}. "
                f"Available: {list(self.ENCODER_CONFIGS.keys())}"
            )
        
        self.encoder_name = encoder_name
        self.config = self.ENCODER_CONFIGS[encoder_name]
        self.frozen_stages = frozen_stages
        
        # Load pretrained backbone
        if pretrained:
            if "efficientnet" in encoder_name:
                self.backbone = self.config["model"](weights=models.EfficientNet_B0_Weights.DEFAULT if encoder_name == "efficientnet_b0" else None)
            else:
                self.backbone = self.config["model"](weights=models.ResNet18_Weights.DEFAULT if encoder_name == "resnet18" else None)
        else:
            self.backbone = self.config["model"](weights=None)
        
        # Modify first conv for different input channels
        if in_channels != 3:
            original_conv = self.backbone.conv1
            self.backbone.conv1 = nn.Conv2d(
                in_channels, 
                original_conv.out_channels,
                kernel_size=original_conv.kernel_size,
                stride=original_conv.stride,
                padding=original_conv.padding,
                bias=original_conv.bias is not None
            )
            # Initialize new conv with pretrained weights (average RGB weights)
            if pretrained:
                with torch.no_grad():
                    # Repeat the RGB weights for each input channel
                    if in_channels > 3:
                        # For 7 channels (WRF), repeat RGB 2 times + use first channel
                        w = original_conv.weight
                        new_w = torch.cat([w, w, w[:, :1]], dim=1)
                    else:
                        # For 1 channel, just use mean
                        new_w = w.mean(dim=1, keepdim=True)
                    self.backbone.conv1.weight = nn.Parameter(new_w)
        
        # Freeze stages if needed
        if frozen_stages >= 0:
            self._freeze_stages(frozen_stages)
        
        # Extract encoder layers
        self._build_encoder_layers()
    
    def _freeze_stages(self, stages: int):
        """Freeze encoder stages."""
        if stages >= 0:
            # Freeze conv1
            for param in self.backbone.conv1.parameters():
                param.requires_grad = False
        
        if stages >= 1:
            # Freeze layer1
            for param in self.backbone.layer1.parameters():
                param.requires_grad = False
        
        if stages >= 2:
            # Freeze layer2
            for param in self.backbone.layer2.parameters():
                param.requires_grad = False
        
        if stages >= 3:
            # Freeze layer3
            for param in self.backbone.layer3.parameters():
                param.requires_grad = False
    
    def _build_encoder_layers(self):
        """Build encoder layer hooks."""
        if "resnet" in self.encoder_name:
            self.layer0 = nn.Sequential(
                self.backbone.conv1,
                self.backbone.bn1,
                self.backbone.relu,
            )
            self.maxpool = self.backbone.maxpool
            self.layer1 = self.backbone.layer1
            self.layer2 = self.backbone.layer2
            self.layer3 = self.backbone.layer3
            self.layer4 = self.backbone.layer4
        elif "efficientnet" in self.encoder_name:
            self.features = self.backbone.features
            self.avgpool = self.backbone.avgpool
    
    def forward(self, x: torch.Tensor) -> List[torch.Tensor]:
        """Return list of feature maps at different scales."""
        features = []
        
        if "resnet" in self.encoder_name:
            x = self.layer0(x)           # 1/4 resolution
            x = self.maxpool(x)
            x = self.layer1(x)            # 1/4 resolution
            features.append(x)
            x = self.layer2(x)            # 1/8 resolution
            features.append(x)
            x = self.layer3(x)            # 1/16 resolution
            features.append(x)
            x = self.layer4(x)            # 1/32 resolution
            features.append(x)
        elif "efficientnet" in self.encoder_name:
            x = self.features(x)
            # EfficientNet: return features at different scales using adaptive pooling
            # These are approximate for skip connections
            pool2 = F.adaptive_avg_pool2d(x, (x.shape[2] // 8, x.shape[3] // 8))
            pool4 = F.adaptive_avg_pool2d(x, (x.shape[2] // 4, x.shape[3] // 4))
            pool8 = F.adaptive_avg_pool2d(x, (x.shape[2] // 2, x.shape[3] // 2))
            features = [pool8, pool4, pool2, x]
        
        return features
    
    def get_output_channels(self) -> List[int]:
        """Return output channels for each feature level."""
        if "resnet" in self.encoder_name:
            if self.encoder_name == "resnet18" or self.encoder_name == "resnet34":
                return [64, 128, 256, 512]  # layer1, layer2, layer3, layer4
            else:
                return [256, 512, 1024, 2048]
        elif "efficientnet" in self.encoder_name:
            if self.encoder_name == "efficientnet_b0":
                return [24, 40, 112, 320]
            elif self.encoder_name == "efficientnet_b1":
                return [24, 40, 112, 320]
            elif self.encoder_name == "efficientnet_b2":
                return [24, 48, 120, 352]
        return self.config["features"]


class UNetPretrained(nn.Module):
    """
    UNet with pretrained encoder.
    
    Combines pretrained ResNet/EfficientNet encoder with UNet decoder
    for improved downscaling performance.
    """
    
    def __init__(
        self,
        encoder_name: str = "resnet18",
        pretrained: bool = True,
        in_channels: int = 7,
        out_channels: int = 2,
        frozen_stages: int = -1,
        use_attention: bool = True,
        use_deep_supervision: bool = True,
    ):
        super().__init__()
        
        # Encoder
        self.encoder = PretrainedEncoder(
            encoder_name=encoder_name,
            pretrained=pretrained,
            in_channels=in_channels,
            frozen_stages=frozen_stages,
        )
        
        encoder_channels = self.encoder.get_output_channels()
        
        # Decoder channels (for upsampling): [256, 128, 64] for 3 levels
        # Skip channels come from encoder: [256, 128, 64]
        decoder_up_channels = encoder_channels[:-1][::-1]  # [256, 128, 64]
        
        # Bottleneck: process deepest features (512 channels)
        bottleneck_in = encoder_channels[-1]
        bottleneck_out = bottleneck_in
        self.bottleneck = nn.Sequential(
            nn.Conv2d(bottleneck_in, bottleneck_out, 3, padding=1),
            nn.BatchNorm2d(bottleneck_out),
            nn.ReLU(inplace=True),
            nn.Conv2d(bottleneck_out, bottleneck_out, 3, padding=1),
            nn.BatchNorm2d(bottleneck_out),
            nn.ReLU(inplace=True),
        )
        
        # Decoder blocks: 3 levels
        # Level 0: 512(bottleneck) -> 256, skip=256(encoder layer2)
        # Level 1: 256 -> 128, skip=128(encoder layer1)  
        # Level 2: 128 -> 64, skip=64(encoder layer0)
        self.upconvs = nn.ModuleList()
        self.decoder_blocks = nn.ModuleList()
        self.attention_gates = nn.ModuleList() if use_attention else None
        
        for i in range(len(decoder_up_channels)):
            # Input channels: bottleneck (512) for i=0, else decoder_up_channels[i-1]
            if i == 0:
                in_ch = bottleneck_out
            else:
                in_ch = decoder_up_channels[i - 1]
            
            out_ch = decoder_up_channels[i]
            skip_ch = decoder_up_channels[i]  # Same as output for skip
            
            # Upsample: in_ch -> out_ch
            self.upconvs.append(
                nn.ConvTranspose2d(
                    in_ch,
                    out_ch,
                    kernel_size=2,
                    stride=2,
                )
            )
            
            # Decoder block input: skip (out_ch) + upconv output (out_ch) = out_ch * 2
            decoder_in = out_ch * 2
            self.decoder_blocks.append(
                nn.Sequential(
                    nn.Conv2d(decoder_in, out_ch, 3, padding=1),
                    nn.BatchNorm2d(out_ch),
                    nn.ReLU(inplace=True),
                    nn.Conv2d(out_ch, out_ch, 3, padding=1),
                    nn.BatchNorm2d(out_ch),
                    nn.ReLU(inplace=True),
                )
            )
            
            # Attention gate
            if use_attention:
                self.attention_gates.append(
                    self._create_attention_gate(out_ch, out_ch, out_ch // 2)
                )
        
        # Final output
        self.final = nn.Conv2d(decoder_up_channels[-1], out_channels, kernel_size=1)
        
        # Deep supervision
        self.use_deep_supervision = use_deep_supervision
        if use_deep_supervision:
            self.deep_supervision_heads = nn.ModuleList()
            for ch in decoder_up_channels:  # Each decoder level
                self.deep_supervision_heads.append(
                    nn.Sequential(
                        nn.Upsample(scale_factor=2, mode="bilinear", align_corners=True),
                        nn.Conv2d(ch, ch // 2, 3, padding=1),
                        nn.BatchNorm2d(ch // 2),
                        nn.ReLU(inplace=True),
                        nn.Conv2d(ch // 2, out_channels, 1),
                    )
                )
    
    def _create_attention_gate(self, F_g: int, F_l: int, F_int: int):
        """Create attention gate module."""
        return AttentionGateModule(F_g, F_l, F_int)


class AttentionGateModule(nn.Module):
    """Attention gate module."""
    
    def __init__(self, F_g: int, F_l: int, F_int: int):
        super().__init__()
        self.W_g = nn.Conv2d(F_g, F_int, 1)
        self.W_x = nn.Conv2d(F_l, F_int, 1)
        self.psi = nn.Conv2d(F_int, 1, 1)
        self.relu = nn.ReLU(inplace=True)
        self.sigmoid = nn.Sigmoid()
    
    def forward(self, g: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
        g1 = self.W_g(g)
        x1 = self.W_x(x)
        psi = self.relu(g1 + x1)
        psi = self.psi(psi)
        return x * self.sigmoid(psi)
    
    def forward(self, x: torch.Tensor):
        # Encoder returns features from shallow to deep: [layer1, layer2, layer3, layer4]
        # = [64, 128, 256, 512]
        encoder_features = self.encoder(x)  # [64, 128, 256, 512]
        
        # Reverse for decoder: [512, 256, 128, 64]
        # We use: encoder_features[3]=512, encoder_features[2]=256, encoder_features[1]=128, encoder_features[0]=64
        skip_features = encoder_features[::-1]  # [512, 256, 128, 64]
        
        # Bottleneck: process deepest features (512 channels)
        x = self.bottleneck(skip_features[0])  # 512 -> 512
        
        # Decoder: 3 levels
        # Level 0: 512->256, skip=256 (features[1])
        # Level 1: 256->128, skip=128 (features[2])
        # Level 2: 128->64, skip=64 (features[3])
        deep_features = []
        
        for i, (upconv, decoder) in enumerate(zip(self.upconvs, self.decoder_blocks)):
            # Skip connection: features[i+1] because skip_features[0] is bottleneck
            skip = skip_features[i + 1]
            
            # Upsample
            x = upconv(x)
            
            # Handle size mismatch
            if x.shape[2:] != skip.shape[2:]:
                x = F.interpolate(x, size=skip.shape[2:], mode="bilinear", align_corners=False)
            
            # Apply attention if enabled
            if self.attention_gates is not None:
                att = self.attention_gates[i]
                skip = skip * torch.sigmoid(att(x, skip))
            
            # Concatenate and decode
            x = torch.cat([skip, x], dim=1)
            x = decoder(x)
            
            if self.use_deep_supervision and i < len(self.deep_supervision_heads):
                deep_features.append(x)
        
        # Final output
        output = self.final(x)
        
        # Deep supervision outputs
        if self.use_deep_supervision:
            outputs = [output]
            for i, head in enumerate(self.deep_supervision_heads):
                if i < len(deep_features):
                    scale_out = head(deep_features[i])
                    outputs.append(scale_out)
            return outputs
        
        return output


class UNetResNet18(nn.Module):
    """Convenience class for ResNet18 encoder."""
    
    def __init__(self, in_channels: int = 7, out_channels: int = 2, **kwargs):
        super().__init__()
        self.model = UNetPretrained(
            encoder_name="resnet18",
            in_channels=in_channels,
            out_channels=out_channels,
            **kwargs,
        )
    
    def forward(self, x):
        return self.model(x)


class UNetResNet34(nn.Module):
    """Convenience class for ResNet34 encoder."""
    
    def __init__(self, in_channels: int = 7, out_channels: int = 2, **kwargs):
        super().__init__()
        self.model = UNetPretrained(
            encoder_name="resnet34",
            in_channels=in_channels,
            out_channels=out_channels,
            **kwargs,
        )
    
    def forward(self, x):
        return self.model(x)


class UNetEfficientNet(nn.Module):
    """Convenience class for EfficientNet-B0 encoder."""
    
    def __init__(self, in_channels: int = 7, out_channels: int = 2, **kwargs):
        super().__init__()
        self.model = UNetPretrained(
            encoder_name="efficientnet_b0",
            in_channels=in_channels,
            out_channels=out_channels,
            **kwargs,
        )
    
    def forward(self, x):
        return self.model(x)


# Model factory
def create_pretrained_model(
    encoder: str = "resnet18",
    in_channels: int = 7,
    out_channels: int = 2,
    pretrained: bool = True,
    **kwargs
):
    """Create pretrained UNet model."""
    models = {
        "resnet18": lambda: UNetPretrained("resnet18", in_channels, out_channels, pretrained, **kwargs),
        "resnet34": lambda: UNetPretrained("resnet34", in_channels, out_channels, pretrained, **kwargs),
        "resnet50": lambda: UNetPretrained("resnet50", in_channels, out_channels, pretrained, **kwargs),
        "efficientnet_b0": lambda: UNetPretrained("efficientnet_b0", in_channels, out_channels, pretrained, **kwargs),
        "efficientnet_b1": lambda: UNetPretrained("efficientnet_b1", in_channels, out_channels, pretrained, **kwargs),
        "efficientnet_b2": lambda: UNetPretrained("efficientnet_b2", in_channels, out_channels, pretrained, **kwargs),
    }
    
    if encoder not in models:
        raise ValueError(f"Unknown encoder: {encoder}. Available: {list(models.keys())}")
    
    return models[encoder]()


if __name__ == "__main__":
    # Test all models
    x = torch.randn(1, 7, 128, 128)
    
    print("=" * 60)
    print("Testing UNet with Pretrained Encoders")
    print("=" * 60)
    
    for encoder in ["resnet18", "resnet34", "efficientnet_b0"]:
        print(f"\n{encoder}:")
        model = UNetPretrained(encoder_name=encoder, in_channels=7, out_channels=2)
        
        with torch.no_grad():
            y = model(x)
            if isinstance(y, list):
                print(f"  Outputs: {[o.shape for o in y]}")
            else:
                print(f"  Output: {y.shape}")
        
        params = sum(p.numel() for p in model.parameters() if p.requires_grad)
        print(f"  Trainable params: {params:,}")
    
    print("\n" + "=" * 60)
    print("Testing frozen encoder (first 2 stages)")
    print("=" * 60)
    
    model = UNetPretrained(
        encoder_name="resnet18",
        in_channels=7,
        out_channels=2,
        frozen_stages=2,
    )
    
    frozen = sum(p.numel() for p in model.encoder.parameters() if not p.requires_grad)
    trainable = sum(p.numel() for p in model.encoder.parameters() if p.requires_grad)
    print(f"Frozen: {frozen:,} | Trainable: {trainable:,}")
